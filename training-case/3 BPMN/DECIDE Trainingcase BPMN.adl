	VALUE "GRAPHREP layer:-1

AVAL showModelInfo:\"Display modelling information\"


SET bShowModelStatus:(cond((_outdevtype != \"printer\") OR (_pageindex = 1) OR (_pagemargintype = \"\""
	      "), 1, 0))

# IF ((showModelInfo = \"1\") AND bShowModelStatus) #ZMI Show model status always on the drawing area"
	      "
IF (bShowModelStatus) 
  # [HOs 2008-04-24: Font set to Arial (see CR#1973)
  #FONT \"Verdana\" h:8pt
  FONT \"Arial\" h:10pt

  SET cm_h_all:0.7cm
  SET cm_h_attribute:0.45cm
  SET cm_w_space:0.4cm
  SET cm_h_space:0.1cm
  SET cm_w_state:0.7cm
  SET cm_w_openclose:0.4cm
AVAL sStatus:\"State\"

    ATTRBOX \"State\"

  SET cm_w_modState:(textw + cm_w_space)


    ATTRBOX \"Name\"


  SET cm_w_modInfo:(textw + cm_w_space)
  TEXTBOX \"Powered by ADOxx\"
  SET cm_w_lastUser:(textw + cm_w_space)
  ATTRBOX \"Date last changed\"
  SET cm_w_lastChange:(textw + cm_w_space)
  SET cm_w_total:(cm_w_space + cm_w_state + cm_w_space + cm_w_modState + (cm_w_space/2) + cm_w_modInf"
	      "o + (cm_w_space / 2) + cm_w_lastUser + (cm_w_space / 2) +       cm_w_lastChange + cm_w_space)

  SET cm_x_start:0.0cm


  CLIP_ROUNDRECT x:(cm_x_start) y:0.0cm w:(cm_w_total) h:(cm_h_all) rx:0.07cm ry:0.07cm
  BITMAP \"db:\\\\symbol_state_bg_gradient.bmp\" x:(cm_x_start) y:0.0cm w:(cm_w_total) h:(cm_h_all)
  PEN color:$b1b1b1 w:0.05cm join:bevel style:inside-frame


  FILL style:null
  CLIP_OFF


  ROUNDRECT x:(cm_x_start) y:0.0cm w:(cm_w_total) h:(cm_h_all) rx:0.07cm ry:0.07cm

  FONT h:10pt


  SET cm_x_start:(cm_x_start + cm_w_space)
  IF (sStatus = \"In process\")
    SET filename:\"db:\\\\symbol_state_draft.bmp\"
    BITMAPINFO (filename)
    BITMAP (filename) x:(cm_x_start-.1cm) y:(cm_h_space) w:(bmpwidth / 96 * 2.54cm) h:(bmpheight / 96"
	      " * 2.54cm)

  ELSIF (sStatus = \"Ready\")
    SET filename:\"db:\\\\symbol_state_qa.bmp\"
    BITMAPINFO (filename)
    BITMAP (filename) x:(cm_x_start-.1cm) y:(cm_h_space) w:(bmpwidth / 96 * 2.54cm) h:(bmpheight / 96"
	      " * 2.54cm)
ELSE
    SET filename:\"db:\\\\symbol_state_released.bmp\"
    BITMAPINFO (filename)
    BITMAP (filename) x:(cm_x_start-.1cm) y:(cm_h_space) w:(bmpwidth / 96 * 2.54cm) h:(bmpheight / 96"
	      " * 2.54cm)
    ENDIF
  # [HOs 2008-04-24: Font set to Arial (see CR#1973)
  #FONT \"Verdana\" h:8pt
  FONT \"Arial\" h:10pt
  SET cm_x_start:(cm_x_start + 0.7cm + cm_w_space)
  SET cm_add_dist:0.04cm
  SET cm_add_dist2:0.02cm
  #Modelstate
  PEN style:null


  FILL style:null
  CLIP_ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_modState "
	      "+ cm_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm ry:0.1cm
    GRADIENT_RECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_modState"
	      " + cm_add_dist) h:(cm_h_attribute + cm_add_dist) style:vert
      color2:$efefef color1:$bdbdbd
    ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_modState + c"
	      "m_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm ry:0.1cm
  CLIP_OFF
  FILL color:snow



  PEN color:snow

  ROUNDRECT x:(cm_x_start) y:(0.0cm + cm_h_space + .03cm) w:(cm_w_modState - .05cm) h:(cm_h_attribute"
	      " - .05cm) rx:0.1cm ry:0.1cm
  # [GSp, 2008.08.29]


    ATTR \"State\" x:(cm_x_start + (cm_w_space / 2)) y:(cm_h_all / 2) h:c


  SET cm_x_start:(cm_x_start + cm_w_modState + (cm_w_space / 2))
  #Modelname  
  PEN style:null



  FILL style:null
  CLIP_ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_modInfo +"
	      " cm_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm ry:0.1cm
    GRADIENT_RECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_modInfo "
	      "+ cm_add_dist) h:(cm_h_attribute + cm_add_dist) style:vert
      color2:$efefef color1:$bdbdbd
    ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_modInfo + cm"
	      "_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm ry:0.1cm
  CLIP_OFF
  PEN color:snow

  FILL color:snow
  ROUNDRECT x:(cm_x_start) y:(0.0cm + cm_h_space + 0.03cm) w:(cm_w_modInfo - 0.05cm) h:(cm_h_attribut"
	      "e - 0.05cm) rx:0.1cm ry:0.1cm


    ATTR \"Name\" x:(cm_x_start + (cm_w_space / 2)) y:(cm_h_all / 2) h:c


  SET cm_x_start:(cm_x_start + cm_w_modInfo + (cm_w_space / 2))
  #Last user
  PEN style:null
  FILL style:null
  CLIP_ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_lastUser "
	      "+ cm_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm ry:0.1cm
    GRADIENT_RECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_lastUser"
	      " + cm_add_dist) h:(cm_h_attribute + cm_add_dist) style:vert
      color2:$efefef color1:$bdbdbd
    ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_lastUser + c"
	      "m_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm ry:0.1cm
  CLIP_OFF
  PEN color:snow

  FILL color:snow
  ROUNDRECT x:(cm_x_start) y:(0.0cm + cm_h_space + 0.03cm) w:(cm_w_lastUser - 0.05cm) h:(cm_h_attribu"
	      "te - 0.05cm) rx:0.1cm ry:0.1cm
  TEXT \"Powered by ADOxx\" x:(cm_x_start + (cm_w_space / 2)) y:(cm_h_all / 2) h:c
  HOTSPOT \"_GoToAceHp_\" text:\"Visit ADOxx.org homepage\" x:(cm_x_start + (cm_w_space / 2)) y:0cm w"
	      ":6cm h:0.7cm

  SET cm_x_start:(cm_x_start + cm_w_lastUser + (cm_w_space / 2))
  #Last change
  PEN style:null
  FILL style:null
  CLIP_ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_lastChang"
	      "e + cm_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm   ry:0.1cm
    GRADIENT_RECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_lastChan"
	      "ge + cm_add_dist) h:(cm_h_attribute + cm_add_dist) style:vert
      color2:$efefef color1:$bdbdbd
    ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_lastChange +"
	      " cm_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm     ry:0.1cm
  CLIP_OFF
  PEN color:snow

  FILL color:snow
  ROUNDRECT x:(cm_x_start) y:(0.0cm + cm_h_space + 0.03cm) w:(cm_w_lastChange - 0.05cm) h:(cm_h_attri"
	      "bute - 0.05cm) rx:0.1cm ry:0.1cm
  ATTR \"Date last changed\" x:(cm_x_start + (cm_w_space / 2)) y:(cm_h_all / 2) h:c
  SET cm_x_start:(cm_x_start + cm_w_lastChange + (cm_w_space/2))
  #Hide model info
  # [HOs 2008-04-24: replaced TEXT by lines because the special characters \"‹\" and \"›\" are not su"
	      "pported by the codepage
  # which BOC recommends for usage on Oracle: Oracle-Codepage \"WE8ISO8859P15\" (CR#2323)
  # Font \"Arial Rounded MT Bold\" is not available on a standard Windows XP after default installati"
	      "on (CR#2322)
  #FONT \"Arial Rounded MT Bold\" h:15pt color:$838080
  #TEXT \"‹\" x:0.13cm y:0.3cm w:c h:c
  #PEN color:$838080 w:0.05cm endcap:round
  #LINE x1:0.13cm y1:0.25cm x2:0.08cm y2:0.35cm
  #LINE x1:0.08cm y1:0.35cm x2:0.13cm y2:0.45cm
   #HOTSPOT \"_ToggleModelInfo_\" text:\"Hide model information\" x:0.02cm y:0.0cm w:0.18cm h:0.7cm
ELSE   
  IF (_outdevtype = \"drawingarea\") 
    FILL style:null
    CLIP_ROUNDRECT x:0.0cm y:0.0cm w:.2cm h:0.7cm rx:0.07cm ry:0.07cm
      GRADIENT_RECT x:0.0cm y:0.0cm w:.2cm h:0.7cm style:vert
                    color1:$efefef color2:$bdbdbd
      PEN color:$b1b1b1 w:0.05cm join:bevel style:inside-frame
      ROUNDRECT x:0.0cm y:0.0cm w:.2cm h:0.7cm rx:0.07cm ry:0.07cm
    CLIP_OFF
    # [HOs 2008-04-24: replaced TEXT by lines because the special characters \"‹\" and \"›\" are not "
	      "supported by the codepage
    # which BOC recommends for usage on Oracle: Oracle-Codepage \"WE8ISO8859P15\" (CR#2323)
    # Font \"Arial Rounded MT Bold\" is not available on a standard Windows XP after default installa"
	      "tion (CR#2322)
    #FONT \"Arial Rounded MT Bold\" h:15pt color:$838080
    #TEXT \"›\" x:0.1cm y:0.3cm w:c h:c
    #PEN color:$838080 w:0.05cm endcap:round
    #LINE x1:0.08cm y1:0.25cm x2:0.13cm y2:0.35cm
    #LINE x1:0.13cm y1:0.35cm x2:0.08cm y2:0.45cm

    #HOTSPOT \"_ToggleModelInfo_\" text:\"Show model information\" x:0.02cm y:0.0cm w:0.18cm h:0.7cm

  ENDIF
 ENDIF


##Copyright
GRAPHREP layer:3
AVAL copy:\"Copyright info\"
# SET copyright:(copy)
 AVAL posi:\"Copyright info position\"
 IF (posi=\"Bottom left\")
    IF(copy = \"Edit the model attributes to display your copyright info\")
        FONT italic
    ENDIF
    ATTR \"Copyright info\" x:0cm y:(h - 1cm) w:l h:b
        FONT color:darkblue
    TEXT (\"Powered by ADOxx\") x:0cm y:(h - 0.5cm) w:l h:b
        FONT underline color:darkblue
    TEXT (\"www.adoxx.org\") x:0cm y:(h) w:l h:b
        #HOTSPOT \"_GoToAceHp_\" text:\"Visit adoxx.org homepage\" x:0cm y:(h) w:4cm h:1cm
 ELSIF (posi = \"Bottom right\")
    IF(copy = \"Edit the model attributes to display your copyright info\")
        FONT italic
    ENDIF
    ATTR \"Copyright info\" x:(w) y:(h - 1cm) w:r h:b
        FONT color:darkblue
    TEXT (\"Powered by ADOxx\") x:(w) y:(h - 0.5cm) w:r h:b
        FONT underline color:darkblue
        TEXT (\"www.adoxx.org\") x:(w) y:(h) w:r h:b
        #HOTSPOT \"_GoToAceHp_\" text:\"Visit adoxx.org homepage\" x:(w - 4cm) y:(h) w:4cm h:1cm
 ELSE
    IF(copy = \"Edit the model attributes to display your copyright info\")
        FONT italic
    ENDIF
        ATTR \"Copyright info\" x:(w) y:1cm w:r h:t
        FONT color:darkblue
    TEXT (\"Powered by ADOxx\") x:(w) y:1.5cm w:r h:t
        FONT underline color:darkblue
    TEXT (\"www.adoxx.org\") x:(w) y:2.0cm w:r h:t
#HOTSPOT \"_GoToAceHp_\" text:\"Visit adoxx.org homepage\" x:(w - 4cm) y:(h) y:1.5cm h:1cm
 ENDIF
##//Copyright"

	ATTRIBUTE <BM Model Attributes>
	VALUE "NOTEBOOK
CHAPTER \"Description\"
ATTR \"Contact person\"
ATTR \"Keywords\" lines:5
ATTR \"Description\" lines:5
ATTR \"Comment\" lines:5
#ATTR \"Language\"

GROUP \"Copyright\"
ATTR \"Copyright info\" 
ATTR \"Copyright info position\" 
ENDGROUP

CHAPTER \"User attributes\"
ATTR \"Model type\"
ATTR \"State\"
ATTR \"Reviewed on\"
ATTR \"Reviewed by\"
CHAPTER \"System attributes\"
ATTR \"Author\" write-protected
ATTR \"Creation date\" write-protected
ATTR \"Last user\" write-protected
ATTR \"Date last changed\" write-protected
ATTR \"Number of objects and relations\" write-protected
ATTR \"Context of version\" write-protected
CHAPTER \"Change history\"
ATTR \"Change history\" lines:30
"

	ATTRIBUTE <LC Graphrep>
	VALUE "GRAPHREP layer:-1

AVAL showModelInfo:\"Display modelling information\"


SET bShowModelStatus:(cond((_outdevtype != \"printer\") OR (_pageindex = 1) OR (_pagemargintype = \"\""
	      "), 1, 0))

# IF ((showModelInfo = \"1\") AND bShowModelStatus) #ZMI Show model status always on the drawing area"
	      "
IF (bShowModelStatus) 
  # [HOs 2008-04-24: Font set to Arial (see CR#1973)
  #FONT \"Verdana\" h:8pt
  FONT \"Arial\" h:10pt

  SET cm_h_all:0.7cm
  SET cm_h_attribute:0.45cm
  SET cm_w_space:0.4cm
  SET cm_h_space:0.1cm
  SET cm_w_state:0.7cm
  SET cm_w_openclose:0.4cm
AVAL sStatus:\"State\"

    ATTRBOX \"State\"

  SET cm_w_modState:(textw + cm_w_space)


    ATTRBOX \"Name\"


  SET cm_w_modInfo:(textw + cm_w_space)
  TEXTBOX \"Powered by ADOxx\"
  SET cm_w_lastUser:(textw + cm_w_space)
  ATTRBOX \"Date last changed\"
  SET cm_w_lastChange:(textw + cm_w_space)
  SET cm_w_total:(cm_w_space + cm_w_state + cm_w_space + cm_w_modState + (cm_w_space/2) + cm_w_modInf"
	      "o + (cm_w_space / 2) + cm_w_lastUser + (cm_w_space / 2) +       cm_w_lastChange + cm_w_space)

  SET cm_x_start:0.0cm


  CLIP_ROUNDRECT x:(cm_x_start) y:0.0cm w:(cm_w_total) h:(cm_h_all) rx:0.07cm ry:0.07cm
  BITMAP \"db:\\\\symbol_state_bg_gradient.bmp\" x:(cm_x_start) y:0.0cm w:(cm_w_total) h:(cm_h_all)
  PEN color:$b1b1b1 w:0.05cm join:bevel style:inside-frame


  FILL style:null
  CLIP_OFF


  ROUNDRECT x:(cm_x_start) y:0.0cm w:(cm_w_total) h:(cm_h_all) rx:0.07cm ry:0.07cm

  FONT h:10pt


  SET cm_x_start:(cm_x_start + cm_w_space)
  IF (sStatus = \"In process\")
    SET filename:\"db:\\\\symbol_state_draft.bmp\"
    BITMAPINFO (filename)
    BITMAP (filename) x:(cm_x_start-.1cm) y:(cm_h_space) w:(bmpwidth / 96 * 2.54cm) h:(bmpheight / 96"
	      " * 2.54cm)

  ELSIF (sStatus = \"Ready\")
    SET filename:\"db:\\\\symbol_state_qa.bmp\"
    BITMAPINFO (filename)
    BITMAP (filename) x:(cm_x_start-.1cm) y:(cm_h_space) w:(bmpwidth / 96 * 2.54cm) h:(bmpheight / 96"
	      " * 2.54cm)
ELSE
    SET filename:\"db:\\\\symbol_state_released.bmp\"
    BITMAPINFO (filename)
    BITMAP (filename) x:(cm_x_start-.1cm) y:(cm_h_space) w:(bmpwidth / 96 * 2.54cm) h:(bmpheight / 96"
	      " * 2.54cm)
    ENDIF
  # [HOs 2008-04-24: Font set to Arial (see CR#1973)
  #FONT \"Verdana\" h:8pt
  FONT \"Arial\" h:10pt
  SET cm_x_start:(cm_x_start + 0.7cm + cm_w_space)
  SET cm_add_dist:0.04cm
  SET cm_add_dist2:0.02cm
  #Modelstate
  PEN style:null


  FILL style:null
  CLIP_ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_modState "
	      "+ cm_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm ry:0.1cm
    GRADIENT_RECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_modState"
	      " + cm_add_dist) h:(cm_h_attribute + cm_add_dist) style:vert
      color2:$efefef color1:$bdbdbd
    ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_modState + c"
	      "m_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm ry:0.1cm
  CLIP_OFF
  FILL color:snow



  PEN color:snow

  ROUNDRECT x:(cm_x_start) y:(0.0cm + cm_h_space + .03cm) w:(cm_w_modState - .05cm) h:(cm_h_attribute"
	      " - .05cm) rx:0.1cm ry:0.1cm
  # [GSp, 2008.08.29]


    ATTR \"State\" x:(cm_x_start + (cm_w_space / 2)) y:(cm_h_all / 2) h:c


  SET cm_x_start:(cm_x_start + cm_w_modState + (cm_w_space / 2))
  #Modelname  
  PEN style:null



  FILL style:null
  CLIP_ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_modInfo +"
	      " cm_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm ry:0.1cm
    GRADIENT_RECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_modInfo "
	      "+ cm_add_dist) h:(cm_h_attribute + cm_add_dist) style:vert
      color2:$efefef color1:$bdbdbd
    ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_modInfo + cm"
	      "_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm ry:0.1cm
  CLIP_OFF
  PEN color:snow

  FILL color:snow
  ROUNDRECT x:(cm_x_start) y:(0.0cm + cm_h_space + 0.03cm) w:(cm_w_modInfo - 0.05cm) h:(cm_h_attribut"
	      "e - 0.05cm) rx:0.1cm ry:0.1cm


    ATTR \"Name\" x:(cm_x_start + (cm_w_space / 2)) y:(cm_h_all / 2) h:c


  SET cm_x_start:(cm_x_start + cm_w_modInfo + (cm_w_space / 2))
  #Last user
  PEN style:null
  FILL style:null
  CLIP_ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_lastUser "
	      "+ cm_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm ry:0.1cm
    GRADIENT_RECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_lastUser"
	      " + cm_add_dist) h:(cm_h_attribute + cm_add_dist) style:vert
      color2:$efefef color1:$bdbdbd
    ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_lastUser + c"
	      "m_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm ry:0.1cm
  CLIP_OFF
  PEN color:snow

  FILL color:snow
  ROUNDRECT x:(cm_x_start) y:(0.0cm + cm_h_space + 0.03cm) w:(cm_w_lastUser - 0.05cm) h:(cm_h_attribu"
	      "te - 0.05cm) rx:0.1cm ry:0.1cm
  TEXT \"Powered by ADOxx\" x:(cm_x_start + (cm_w_space / 2)) y:(cm_h_all / 2) h:c
  HOTSPOT \"_GoToAceHp_\" text:\"Visit ADOxx.org homepage\" x:(cm_x_start + (cm_w_space / 2)) y:0cm w"
	      ":6cm h:0.7cm

  SET cm_x_start:(cm_x_start + cm_w_lastUser + (cm_w_space / 2))
  #Last change
  PEN style:null
  FILL style:null
  CLIP_ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_lastChang"
	      "e + cm_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm   ry:0.1cm
    GRADIENT_RECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_lastChan"
	      "ge + cm_add_dist) h:(cm_h_attribute + cm_add_dist) style:vert
      color2:$efefef color1:$bdbdbd
    ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_lastChange +"
	      " cm_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm     ry:0.1cm
  CLIP_OFF
  PEN color:snow

  FILL color:snow
  ROUNDRECT x:(cm_x_start) y:(0.0cm + cm_h_space + 0.03cm) w:(cm_w_lastChange - 0.05cm) h:(cm_h_attri"
	      "bute - 0.05cm) rx:0.1cm ry:0.1cm
  ATTR \"Date last changed\" x:(cm_x_start + (cm_w_space / 2)) y:(cm_h_all / 2) h:c
  SET cm_x_start:(cm_x_start + cm_w_lastChange + (cm_w_space/2))
  #Hide model info
  # [HOs 2008-04-24: replaced TEXT by lines because the special characters \"‹\" and \"›\" are not su"
	      "pported by the codepage
  # which BOC recommends for usage on Oracle: Oracle-Codepage \"WE8ISO8859P15\" (CR#2323)
  # Font \"Arial Rounded MT Bold\" is not available on a standard Windows XP after default installati"
	      "on (CR#2322)
  #FONT \"Arial Rounded MT Bold\" h:15pt color:$838080
  #TEXT \"‹\" x:0.13cm y:0.3cm w:c h:c
  #PEN color:$838080 w:0.05cm endcap:round
  #LINE x1:0.13cm y1:0.25cm x2:0.08cm y2:0.35cm
  #LINE x1:0.08cm y1:0.35cm x2:0.13cm y2:0.45cm
   #HOTSPOT \"_ToggleModelInfo_\" text:\"Hide model information\" x:0.02cm y:0.0cm w:0.18cm h:0.7cm
ELSE   
  IF (_outdevtype = \"drawingarea\") 
    FILL style:null
