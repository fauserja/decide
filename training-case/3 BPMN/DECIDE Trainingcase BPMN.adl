	      "supported by the codepage
    # which BOC recommends for usage on Oracle: Oracle-Codepage \"WE8ISO8859P15\" (CR#2323)
    # Font \"Arial Rounded MT Bold\" is not available on a standard Windows XP after default installa"
	      "tion (CR#2322)
    #FONT \"Arial Rounded MT Bold\" h:15pt color:$838080
    #TEXT \"›\" x:0.1cm y:0.3cm w:c h:c
    #PEN color:$838080 w:0.05cm endcap:round
    #LINE x1:0.08cm y1:0.25cm x2:0.13cm y2:0.35cm
    #LINE x1:0.13cm y1:0.35cm x2:0.08cm y2:0.45cm

    #HOTSPOT \"_ToggleModelInfo_\" text:\"Show model information\" x:0.02cm y:0.0cm w:0.18cm h:0.7cm

  ENDIF
 ENDIF


##Copyright
GRAPHREP layer:3
AVAL copy:\"Copyright info\"
# SET copyright:(copy)
 AVAL posi:\"Copyright info position\"
 IF (posi=\"Bottom left\")
    IF(copy = \"Edit the model attributes to display your copyright info\")
        FONT italic
    ENDIF
    ATTR \"Copyright info\" x:0cm y:(h - 1cm) w:l h:b
        FONT color:darkblue
    TEXT (\"Powered by ADOxx\") x:0cm y:(h - 0.5cm) w:l h:b
        FONT underline color:darkblue
    TEXT (\"www.adoxx.org\") x:0cm y:(h) w:l h:b
        #HOTSPOT \"_GoToAceHp_\" text:\"Visit adoxx.org homepage\" x:0cm y:(h) w:4cm h:1cm
 ELSIF (posi = \"Bottom right\")
    IF(copy = \"Edit the model attributes to display your copyright info\")
        FONT italic
    ENDIF
    ATTR \"Copyright info\" x:(w) y:(h - 1cm) w:r h:b
        FONT color:darkblue
    TEXT (\"Powered by ADOxx\") x:(w) y:(h - 0.5cm) w:r h:b
        FONT underline color:darkblue
        TEXT (\"www.adoxx.org\") x:(w) y:(h) w:r h:b
        #HOTSPOT \"_GoToAceHp_\" text:\"Visit adoxx.org homepage\" x:(w - 4cm) y:(h) w:4cm h:1cm
 ELSE
    IF(copy = \"Edit the model attributes to display your copyright info\")
        FONT italic
    ENDIF
        ATTR \"Copyright info\" x:(w) y:1cm w:r h:t
        FONT color:darkblue
    TEXT (\"Powered by ADOxx\") x:(w) y:1.5cm w:r h:t
        FONT underline color:darkblue
    TEXT (\"www.adoxx.org\") x:(w) y:2.0cm w:r h:t
#HOTSPOT \"_GoToAceHp_\" text:\"Visit adoxx.org homepage\" x:(w - 4cm) y:(h) y:1.5cm h:1cm
 ENDIF
