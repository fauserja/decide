	ATTRIBUTE <BMC Graphrep>
	VALUE "GRAPHREP layer:-1
AVAL name:\"Name\" # model name
AVAL type:\"Type\" # model type name
AVAL count:\"Number of objects and relations\"
SET y:0.5cm
FONT h:24pt color:black
TEXT (name) x:0.7cm y:(y) w:l h:t
SET y:(y + 24pt + 0.3cm)
FONT h:12pt color:gray
#TEXT (\"Modeltype:\" + count) x:0.5cm y:(y) w:l h:t

FONT h:12pt italic
TEXT \"Based on \\\"The Business Model Canvas\\\" by Strategizer\" x:0.2cm y:(h-12pt) h:b
FONT h:12pt color:darkblue style:\"underline\"
TEXT \"strategizer.com\" x:0.2cm y:(h) h:b
BITMAPINFO (\"db:\\\\cc.png\")
BITMAP (\"db:\\\\cc.png\") x:0.2cm y:(h-2.7cm-37pt) w:(bmpwidth / 96 * 2.54cm) h:(bmpheight / 96 * 2."
	      "54cm)
FONT h:12pt
TEXT \"This work is licensed under the Creative Commons Attribution-Share Alike 3.0 Unported License."
	      " To view a copy of this license, visit:\" x:0.2cm y:(h-2.2cm) h:b
FONT h:12pt color:darkblue style:\"underline\"
TEXT \"http://creativecommons.org/licenses/by-sa/3.0/ or send a letter to Creative Commons, 171 Secon"
	      "d Street, Suite 300, San Francisco, California, 94105, USA.\" x:0.2cm y:(h-1.7cm) h:b"

	ATTRIBUTE <Modelling Stack GraphRep>
	VALUE "GRAPHREP
SET x_param:10cm
SET y_param:7cm

FILL color:white
RECTANGLE x:(-0.5*x_param) y:(-0.6*y_param) w: (x_param) h:(y_param+1cm)
TEXT \"Business Modelling\" x:(-0.5*x_param/2) y:(-0.6*y_param) w:c
HOTSPOT \"Business Modelling\" x:(-0.5*x_param) y:(-0.6*y_param) w: (x_param) h:(3cm)
RECTANGLE x:(-0.5*x_param+0.035*x_param) y:(-0.5*y_param+0.03*y_param) w: (0.17*x_param) h:(0.72*y_pa"
	      "ram)
TEXT \"Key Partners\"  x:(-0.5*x_param+0.045*x_param) y:(-0.5*y_param+0.03*y_param) w:l:2cm h:t:3cm l"
	      "ine-break:rigorous
HOTSPOT \"Key Partners\" x:(-0.5*x_param+0.035*x_param) y:(-0.5*y_param+0.03*y_param) w: (0.17*x_para"
	      "m) h:(0.72*y_param)
RECTANGLE x:(-0.5*x_param+0.225*x_param) y:(-0.5*y_param+0.03*y_param) w: (0.17*x_param) h:(0.33*y_pa"
	      "ram)
TEXT \"Key Activities\" x:(-0.5*x_param+0.240*x_param) y:(-0.5*y_param+0.03*y_param) w:l:2cm h:t:3cm "
	      "line-break:rigorous
HOTSPOT \"Key Activities\" x:(-0.5*x_param+0.225*x_param) y:(-0.5*y_param+0.03*y_param) w: (0.17*x_pa"
	      "ram) h:(0.33*y_param)
RECTANGLE x:(-0.5*x_param+0.415*x_param) y:(-0.5*y_param+0.03*y_param) w: (0.17*x_param) h:(0.72*y_pa"
	      "ram)
TEXT \"Value Proposition\" x:(-0.5*x_param+0.42*x_param) y:(-0.5*y_param+0.03*y_param) w:l:2cm h:t:3c"
	      "m line-break:rigorous
HOTSPOT \"Value Propositions\" x:(-0.5*x_param+0.415*x_param) y:(-0.5*y_param+0.03*y_param) w: (0.17*"
	      "x_param) h:(0.72*y_param)
RECTANGLE x:(-0.5*x_param+0.605*x_param) y:(-0.5*y_param+0.03*y_param) w: (0.17*x_param) h:(0.33*y_pa"
	      "ram)
TEXT \"Cust. Rel.\" x:(-0.5*x_param+0.605*x_param) y:(-0.5*y_param+0.03*y_param) w:l:2cm ht:t:3cm lin"
	      "e-break:rigorous
HOTSPOT \"Customer Relations\" x:(-0.5*x_param+0.605*x_param) y:(-0.5*y_param+0.03*y_param) w: (0.17*"
	      "x_param) h:(0.33*y_param)
RECTANGLE x:(-0.5*x_param+0.795*x_param) y:(-0.5*y_param+0.03*y_param) w: (0.17*x_param) h:(0.72*y_pa"
	      "ram)
TEXT \"Cust. Segments.\" x:(-0.5*x_param+0.795*x_param) y:(-0.5*y_param+0.03*y_param) w:l:2cm h:t:3cm"
	      " line-break:rigorous
HOTSPOT \"Customer Segments\" x:(-0.5*x_param+0.795*x_param) y:(-0.5*y_param+0.03*y_param) w: (0.17*x"
	      "_param) h:(0.72*y_param)
RECTANGLE x:(-0.5*x_param+0.225*x_param) y:(-0.5*y_param+0.42*y_param) w: (0.17*x_param) h:(0.33*y_pa"
	      "ram)
TEXT \"Key Resources\" x:(-0.5*x_param+0.225*x_param) y:(-0.5*y_param+0.42*y_param) w:l:2cm h:t:3cm l"
	      "ine-break:rigorous
HOTSPOT \"Key Resources\" x:(-0.5*x_param+0.225*x_param) y:(-0.5*y_param+0.42*y_param) w: (0.17*x_par"
	      "am) h:(0.33*y_param)
RECTANGLE x:(-0.5*x_param+0.605*x_param) y:(-0.5*y_param+0.42*y_param) w: (0.17*x_param) h:(0.33*y_pa"
	      "ram)
TEXT \"Comm. Channels\" x:(-0.5*x_param+0.605*x_param) y:(-0.5*y_param+0.42*y_param) w:l:2cm h:t:3cm "
	      "line-break:rigorous
HOTSPOT \"Communication Channels\" x:(-0.5*x_param+0.605*x_param) y:(-0.5*y_param+0.42*y_param) w: (0"
	      ".17*x_param) h:(0.33*y_param)
RECTANGLE x:(-0.5*x_param+0.035*x_param) y:(0.28*y_param) w: (0.445*x_param) h:(0.14*x_param)
TEXT \"Cost Structure\" x:(-0.5*x_param+0.045*x_param) y:(0.28*y_param) w:l:2cm h:t:2cm
HOTSPOT \"Cost Structure\"  x:(-0.5*x_param+0.035*x_param) y:(0.28*y_param) w: (0.445*x_param) h:(0.1"
	      "4*x_param)
RECTANGLE x:(0.02*x_param) y:(0.28*y_param) w: (0.445*x_param) h:(0.14*x_param)
TEXT \"Revenue Stream\" x:(0.03*x_param) y:(0.28*y_param) w:l:2cm h:t:3cm line-break:rigorous
HOTSPOT \"Revenue Stream\" x:(0.02*x_param) y:(0.28*y_param) w: (0.445*x_param) h:(0.14*x_param)"

	ATTRIBUTE <Is continuous NVF Analysis active>
	VALUE "no"

	ATTRIBUTE <e3 Value Model Attributes>
	VALUE "NOTEBOOK
CHAPTER \"Description\"
ATTR \"Contact person\"
ATTR \"Keywords\" lines:5
ATTR \"Description\" lines:5
ATTR \"Comment\" lines:5
#ATTR \"Language\"

GROUP \"Copyright\"
ATTR \"Copyright info\" 
ATTR \"Copyright info position\" 
ENDGROUP

CHAPTER \"User attributes\"
ATTR \"Is continuous NVF Analysis active\"
ATTR \"Model type\"
ATTR \"State\"
ATTR \"Reviewed on\"
ATTR \"Reviewed by\"
CHAPTER \"System attributes\"
ATTR \"Author\" write-protected
ATTR \"Creation date\" write-protected
ATTR \"Last user\" write-protected
ATTR \"Date last changed\" write-protected
ATTR \"Number of objects and relations\" write-protected
ATTR \"Context of version\" write-protected
CHAPTER \"Change history\"
ATTR \"Change history\" lines:30


"

	ATTRIBUTE <BM Model Graphrep>
	VALUE "GRAPHREP layer:-1

AVAL showModelInfo:\"Display modelling information\"


SET bShowModelStatus:(cond((_outdevtype != \"printer\") OR (_pageindex = 1) OR (_pagemargintype = \"\""
	      "), 1, 0))

# IF ((showModelInfo = \"1\") AND bShowModelStatus) #ZMI Show model status always on the drawing area"
	      "
IF (bShowModelStatus) 
  # [HOs 2008-04-24: Font set to Arial (see CR#1973)
  #FONT \"Verdana\" h:8pt
  FONT \"Arial\" h:10pt

  SET cm_h_all:0.7cm
  SET cm_h_attribute:0.45cm
  SET cm_w_space:0.4cm
  SET cm_h_space:0.1cm
  SET cm_w_state:0.7cm
  SET cm_w_openclose:0.4cm
AVAL sStatus:\"State\"

    ATTRBOX \"State\"

  SET cm_w_modState:(textw + cm_w_space)


    ATTRBOX \"Name\"


  SET cm_w_modInfo:(textw + cm_w_space)
  TEXTBOX \"Powered by ADOxx\"
  SET cm_w_lastUser:(textw + cm_w_space)
  ATTRBOX \"Date last changed\"
  SET cm_w_lastChange:(textw + cm_w_space)
  SET cm_w_total:(cm_w_space + cm_w_state + cm_w_space + cm_w_modState + (cm_w_space/2) + cm_w_modInf"
	      "o + (cm_w_space / 2) + cm_w_lastUser + (cm_w_space / 2) +       cm_w_lastChange + cm_w_space)

  SET cm_x_start:0.0cm


  CLIP_ROUNDRECT x:(cm_x_start) y:0.0cm w:(cm_w_total) h:(cm_h_all) rx:0.07cm ry:0.07cm
  BITMAP \"db:\\\\symbol_state_bg_gradient.bmp\" x:(cm_x_start) y:0.0cm w:(cm_w_total) h:(cm_h_all)
  PEN color:$b1b1b1 w:0.05cm join:bevel style:inside-frame


  FILL style:null
  CLIP_OFF


  ROUNDRECT x:(cm_x_start) y:0.0cm w:(cm_w_total) h:(cm_h_all) rx:0.07cm ry:0.07cm

  FONT h:10pt


  SET cm_x_start:(cm_x_start + cm_w_space)
  IF (sStatus = \"In process\")
    SET filename:\"db:\\\\symbol_state_draft.bmp\"
    BITMAPINFO (filename)
    BITMAP (filename) x:(cm_x_start-.1cm) y:(cm_h_space) w:(bmpwidth / 96 * 2.54cm) h:(bmpheight / 96"
	      " * 2.54cm)

  ELSIF (sStatus = \"Ready\")
    SET filename:\"db:\\\\symbol_state_qa.bmp\"
    BITMAPINFO (filename)
    BITMAP (filename) x:(cm_x_start-.1cm) y:(cm_h_space) w:(bmpwidth / 96 * 2.54cm) h:(bmpheight / 96"
	      " * 2.54cm)
ELSE
    SET filename:\"db:\\\\symbol_state_released.bmp\"
    BITMAPINFO (filename)
    BITMAP (filename) x:(cm_x_start-.1cm) y:(cm_h_space) w:(bmpwidth / 96 * 2.54cm) h:(bmpheight / 96"
	      " * 2.54cm)
    ENDIF
  # [HOs 2008-04-24: Font set to Arial (see CR#1973)
  #FONT \"Verdana\" h:8pt
  FONT \"Arial\" h:10pt
  SET cm_x_start:(cm_x_start + 0.7cm + cm_w_space)
  SET cm_add_dist:0.04cm
  SET cm_add_dist2:0.02cm
  #Modelstate
  PEN style:null


  FILL style:null
  CLIP_ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_modState "
	      "+ cm_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm ry:0.1cm
    GRADIENT_RECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_modState"
	      " + cm_add_dist) h:(cm_h_attribute + cm_add_dist) style:vert
      color2:$efefef color1:$bdbdbd
    ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_modState + c"
	      "m_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm ry:0.1cm
  CLIP_OFF
  FILL color:snow



  PEN color:snow

  ROUNDRECT x:(cm_x_start) y:(0.0cm + cm_h_space + .03cm) w:(cm_w_modState - .05cm) h:(cm_h_attribute"
	      " - .05cm) rx:0.1cm ry:0.1cm
  # [GSp, 2008.08.29]


    ATTR \"State\" x:(cm_x_start + (cm_w_space / 2)) y:(cm_h_all / 2) h:c


  SET cm_x_start:(cm_x_start + cm_w_modState + (cm_w_space / 2))
  #Modelname  
  PEN style:null



  FILL style:null
  CLIP_ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_modInfo +"
	      " cm_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm ry:0.1cm
    GRADIENT_RECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_modInfo "
	      "+ cm_add_dist) h:(cm_h_attribute + cm_add_dist) style:vert
      color2:$efefef color1:$bdbdbd
    ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_modInfo + cm"
	      "_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm ry:0.1cm
  CLIP_OFF
  PEN color:snow

  FILL color:snow
  ROUNDRECT x:(cm_x_start) y:(0.0cm + cm_h_space + 0.03cm) w:(cm_w_modInfo - 0.05cm) h:(cm_h_attribut"
	      "e - 0.05cm) rx:0.1cm ry:0.1cm


    ATTR \"Name\" x:(cm_x_start + (cm_w_space / 2)) y:(cm_h_all / 2) h:c


  SET cm_x_start:(cm_x_start + cm_w_modInfo + (cm_w_space / 2))
  #Last user
  PEN style:null
  FILL style:null
  CLIP_ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_lastUser "
	      "+ cm_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm ry:0.1cm
    GRADIENT_RECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_lastUser"
	      " + cm_add_dist) h:(cm_h_attribute + cm_add_dist) style:vert
      color2:$efefef color1:$bdbdbd
    ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_lastUser + c"
	      "m_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm ry:0.1cm
  CLIP_OFF
  PEN color:snow

  FILL color:snow
  ROUNDRECT x:(cm_x_start) y:(0.0cm + cm_h_space + 0.03cm) w:(cm_w_lastUser - 0.05cm) h:(cm_h_attribu"
	      "te - 0.05cm) rx:0.1cm ry:0.1cm
  TEXT \"Powered by ADOxx\" x:(cm_x_start + (cm_w_space / 2)) y:(cm_h_all / 2) h:c
  HOTSPOT \"_GoToAceHp_\" text:\"Visit ADOxx.org homepage\" x:(cm_x_start + (cm_w_space / 2)) y:0cm w"
	      ":6cm h:0.7cm

  SET cm_x_start:(cm_x_start + cm_w_lastUser + (cm_w_space / 2))
  #Last change
  PEN style:null
  FILL style:null
  CLIP_ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_lastChang"
	      "e + cm_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm   ry:0.1cm
    GRADIENT_RECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_lastChan"
	      "ge + cm_add_dist) h:(cm_h_attribute + cm_add_dist) style:vert
      color2:$efefef color1:$bdbdbd
    ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_lastChange +"
	      " cm_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm     ry:0.1cm
  CLIP_OFF
  PEN color:snow

  FILL color:snow
  ROUNDRECT x:(cm_x_start) y:(0.0cm + cm_h_space + 0.03cm) w:(cm_w_lastChange - 0.05cm) h:(cm_h_attri"
	      "bute - 0.05cm) rx:0.1cm ry:0.1cm
  ATTR \"Date last changed\" x:(cm_x_start + (cm_w_space / 2)) y:(cm_h_all / 2) h:c
  SET cm_x_start:(cm_x_start + cm_w_lastChange + (cm_w_space/2))
  #Hide model info
  # [HOs 2008-04-24: replaced TEXT by lines because the special characters \"‹\" and \"›\" are not su"
	      "pported by the codepage
  # which BOC recommends for usage on Oracle: Oracle-Codepage \"WE8ISO8859P15\" (CR#2323)
  # Font \"Arial Rounded MT Bold\" is not available on a standard Windows XP after default installati"
	      "on (CR#2322)
  #FONT \"Arial Rounded MT Bold\" h:15pt color:$838080
  #TEXT \"‹\" x:0.13cm y:0.3cm w:c h:c
  #PEN color:$838080 w:0.05cm endcap:round
  #LINE x1:0.13cm y1:0.25cm x2:0.08cm y2:0.35cm
  #LINE x1:0.08cm y1:0.35cm x2:0.13cm y2:0.45cm
   #HOTSPOT \"_ToggleModelInfo_\" text:\"Hide model information\" x:0.02cm y:0.0cm w:0.18cm h:0.7cm
ELSE   
  IF (_outdevtype = \"drawingarea\") 
    FILL style:null
    CLIP_ROUNDRECT x:0.0cm y:0.0cm w:.2cm h:0.7cm rx:0.07cm ry:0.07cm
      GRADIENT_RECT x:0.0cm y:0.0cm w:.2cm h:0.7cm style:vert
                    color1:$efefef color2:$bdbdbd
      PEN color:$b1b1b1 w:0.05cm join:bevel style:inside-frame
      ROUNDRECT x:0.0cm y:0.0cm w:.2cm h:0.7cm rx:0.07cm ry:0.07cm
    CLIP_OFF
    # [HOs 2008-04-24: replaced TEXT by lines because the special characters \"‹\" and \"›\" are not "
	      "supported by the codepage
    # which BOC recommends for usage on Oracle: Oracle-Codepage \"WE8ISO8859P15\" (CR#2323)
    # Font \"Arial Rounded MT Bold\" is not available on a standard Windows XP after default installa"
	      "tion (CR#2322)
    #FONT \"Arial Rounded MT Bold\" h:15pt color:$838080
    #TEXT \"›\" x:0.1cm y:0.3cm w:c h:c
    #PEN color:$838080 w:0.05cm endcap:round
    #LINE x1:0.08cm y1:0.25cm x2:0.13cm y2:0.35cm
    #LINE x1:0.13cm y1:0.35cm x2:0.08cm y2:0.45cm

    #HOTSPOT \"_ToggleModelInfo_\" text:\"Show model information\" x:0.02cm y:0.0cm w:0.18cm h:0.7cm

  ENDIF
 ENDIF


##Copyright
GRAPHREP layer:3
AVAL copy:\"Copyright info\"
# SET copyright:(copy)
 AVAL posi:\"Copyright info position\"
 IF (posi=\"Bottom left\")
    IF(copy = \"Edit the model attributes to display your copyright info\")
        FONT italic
    ENDIF
    ATTR \"Copyright info\" x:0cm y:(h - 1cm) w:l h:b
        FONT color:darkblue
    TEXT (\"Powered by ADOxx\") x:0cm y:(h - 0.5cm) w:l h:b
        FONT underline color:darkblue
    TEXT (\"www.adoxx.org\") x:0cm y:(h) w:l h:b
        #HOTSPOT \"_GoToAceHp_\" text:\"Visit adoxx.org homepage\" x:0cm y:(h) w:4cm h:1cm
 ELSIF (posi = \"Bottom right\")
    IF(copy = \"Edit the model attributes to display your copyright info\")
        FONT italic
    ENDIF
    ATTR \"Copyright info\" x:(w) y:(h - 1cm) w:r h:b
        FONT color:darkblue
    TEXT (\"Powered by ADOxx\") x:(w) y:(h - 0.5cm) w:r h:b
        FONT underline color:darkblue
        TEXT (\"www.adoxx.org\") x:(w) y:(h) w:r h:b
        #HOTSPOT \"_GoToAceHp_\" text:\"Visit adoxx.org homepage\" x:(w - 4cm) y:(h) w:4cm h:1cm
 ELSE
    IF(copy = \"Edit the model attributes to display your copyright info\")
        FONT italic
    ENDIF
        ATTR \"Copyright info\" x:(w) y:1cm w:r h:t
        FONT color:darkblue
    TEXT (\"Powered by ADOxx\") x:(w) y:1.5cm w:r h:t
        FONT underline color:darkblue
    TEXT (\"www.adoxx.org\") x:(w) y:2.0cm w:r h:t
#HOTSPOT \"_GoToAceHp_\" text:\"Visit adoxx.org homepage\" x:(w - 4cm) y:(h) y:1.5cm h:1cm
 ENDIF
##//Copyright"

	ATTRIBUTE <BM Model Attributes>
	VALUE "NOTEBOOK
CHAPTER \"Description\"
ATTR \"Contact person\"
ATTR \"Keywords\" lines:5
ATTR \"Description\" lines:5
ATTR \"Comment\" lines:5
#ATTR \"Language\"

GROUP \"Copyright\"
ATTR \"Copyright info\" 
ATTR \"Copyright info position\" 
ENDGROUP

CHAPTER \"User attributes\"
ATTR \"Model type\"
ATTR \"State\"
ATTR \"Reviewed on\"
ATTR \"Reviewed by\"
CHAPTER \"System attributes\"
ATTR \"Author\" write-protected
ATTR \"Creation date\" write-protected
ATTR \"Last user\" write-protected
ATTR \"Date last changed\" write-protected
ATTR \"Number of objects and relations\" write-protected
ATTR \"Context of version\" write-protected
CHAPTER \"Change history\"
ATTR \"Change history\" lines:30
"

	ATTRIBUTE <LC Graphrep>
	VALUE "GRAPHREP layer:-1

AVAL showModelInfo:\"Display modelling information\"


SET bShowModelStatus:(cond((_outdevtype != \"printer\") OR (_pageindex = 1) OR (_pagemargintype = \"\""
	      "), 1, 0))

# IF ((showModelInfo = \"1\") AND bShowModelStatus) #ZMI Show model status always on the drawing area"
	      "
IF (bShowModelStatus) 
  # [HOs 2008-04-24: Font set to Arial (see CR#1973)
  #FONT \"Verdana\" h:8pt
  FONT \"Arial\" h:10pt

  SET cm_h_all:0.7cm
  SET cm_h_attribute:0.45cm
  SET cm_w_space:0.4cm
  SET cm_h_space:0.1cm
  SET cm_w_state:0.7cm
  SET cm_w_openclose:0.4cm
AVAL sStatus:\"State\"

    ATTRBOX \"State\"

  SET cm_w_modState:(textw + cm_w_space)


    ATTRBOX \"Name\"


  SET cm_w_modInfo:(textw + cm_w_space)
  TEXTBOX \"Powered by ADOxx\"
  SET cm_w_lastUser:(textw + cm_w_space)
  ATTRBOX \"Date last changed\"
  SET cm_w_lastChange:(textw + cm_w_space)
  SET cm_w_total:(cm_w_space + cm_w_state + cm_w_space + cm_w_modState + (cm_w_space/2) + cm_w_modInf"
	      "o + (cm_w_space / 2) + cm_w_lastUser + (cm_w_space / 2) +       cm_w_lastChange + cm_w_space)

  SET cm_x_start:0.0cm


  CLIP_ROUNDRECT x:(cm_x_start) y:0.0cm w:(cm_w_total) h:(cm_h_all) rx:0.07cm ry:0.07cm
  BITMAP \"db:\\\\symbol_state_bg_gradient.bmp\" x:(cm_x_start) y:0.0cm w:(cm_w_total) h:(cm_h_all)
  PEN color:$b1b1b1 w:0.05cm join:bevel style:inside-frame


  FILL style:null
  CLIP_OFF


  ROUNDRECT x:(cm_x_start) y:0.0cm w:(cm_w_total) h:(cm_h_all) rx:0.07cm ry:0.07cm

  FONT h:10pt


  SET cm_x_start:(cm_x_start + cm_w_space)
  IF (sStatus = \"In process\")
    SET filename:\"db:\\\\symbol_state_draft.bmp\"
    BITMAPINFO (filename)
    BITMAP (filename) x:(cm_x_start-.1cm) y:(cm_h_space) w:(bmpwidth / 96 * 2.54cm) h:(bmpheight / 96"
	      " * 2.54cm)

  ELSIF (sStatus = \"Ready\")
    SET filename:\"db:\\\\symbol_state_qa.bmp\"
    BITMAPINFO (filename)
    BITMAP (filename) x:(cm_x_start-.1cm) y:(cm_h_space) w:(bmpwidth / 96 * 2.54cm) h:(bmpheight / 96"
	      " * 2.54cm)
ELSE
    SET filename:\"db:\\\\symbol_state_released.bmp\"
    BITMAPINFO (filename)
    BITMAP (filename) x:(cm_x_start-.1cm) y:(cm_h_space) w:(bmpwidth / 96 * 2.54cm) h:(bmpheight / 96"
	      " * 2.54cm)
    ENDIF
  # [HOs 2008-04-24: Font set to Arial (see CR#1973)
  #FONT \"Verdana\" h:8pt
  FONT \"Arial\" h:10pt
  SET cm_x_start:(cm_x_start + 0.7cm + cm_w_space)
  SET cm_add_dist:0.04cm
  SET cm_add_dist2:0.02cm
  #Modelstate
  PEN style:null


  FILL style:null
  CLIP_ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_modState "
	      "+ cm_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm ry:0.1cm
    GRADIENT_RECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_modState"
	      " + cm_add_dist) h:(cm_h_attribute + cm_add_dist) style:vert
      color2:$efefef color1:$bdbdbd
    ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_modState + c"
	      "m_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm ry:0.1cm
  CLIP_OFF
  FILL color:snow



  PEN color:snow

  ROUNDRECT x:(cm_x_start) y:(0.0cm + cm_h_space + .03cm) w:(cm_w_modState - .05cm) h:(cm_h_attribute"
	      " - .05cm) rx:0.1cm ry:0.1cm
  # [GSp, 2008.08.29]


    ATTR \"State\" x:(cm_x_start + (cm_w_space / 2)) y:(cm_h_all / 2) h:c


  SET cm_x_start:(cm_x_start + cm_w_modState + (cm_w_space / 2))
  #Modelname  
  PEN style:null



  FILL style:null
  CLIP_ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_modInfo +"
	      " cm_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm ry:0.1cm
    GRADIENT_RECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_modInfo "
	      "+ cm_add_dist) h:(cm_h_attribute + cm_add_dist) style:vert
      color2:$efefef color1:$bdbdbd
    ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_modInfo + cm"
	      "_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm ry:0.1cm
  CLIP_OFF
  PEN color:snow

  FILL color:snow
  ROUNDRECT x:(cm_x_start) y:(0.0cm + cm_h_space + 0.03cm) w:(cm_w_modInfo - 0.05cm) h:(cm_h_attribut"
	      "e - 0.05cm) rx:0.1cm ry:0.1cm


    ATTR \"Name\" x:(cm_x_start + (cm_w_space / 2)) y:(cm_h_all / 2) h:c


  SET cm_x_start:(cm_x_start + cm_w_modInfo + (cm_w_space / 2))
  #Last user
  PEN style:null
  FILL style:null
  CLIP_ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_lastUser "
	      "+ cm_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm ry:0.1cm
    GRADIENT_RECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_lastUser"
	      " + cm_add_dist) h:(cm_h_attribute + cm_add_dist) style:vert
      color2:$efefef color1:$bdbdbd
    ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_lastUser + c"
	      "m_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm ry:0.1cm
  CLIP_OFF
  PEN color:snow

  FILL color:snow
  ROUNDRECT x:(cm_x_start) y:(0.0cm + cm_h_space + 0.03cm) w:(cm_w_lastUser - 0.05cm) h:(cm_h_attribu"
	      "te - 0.05cm) rx:0.1cm ry:0.1cm
  TEXT \"Powered by ADOxx\" x:(cm_x_start + (cm_w_space / 2)) y:(cm_h_all / 2) h:c
  HOTSPOT \"_GoToAceHp_\" text:\"Visit ADOxx.org homepage\" x:(cm_x_start + (cm_w_space / 2)) y:0cm w"
	      ":6cm h:0.7cm

  SET cm_x_start:(cm_x_start + cm_w_lastUser + (cm_w_space / 2))
  #Last change
  PEN style:null
  FILL style:null
  CLIP_ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_lastChang"
	      "e + cm_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm   ry:0.1cm
    GRADIENT_RECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_lastChan"
	      "ge + cm_add_dist) h:(cm_h_attribute + cm_add_dist) style:vert
      color2:$efefef color1:$bdbdbd
    ROUNDRECT x:(cm_x_start - cm_add_dist) y:(0.0cm + cm_h_space - cm_add_dist2) w:(cm_w_lastChange +"
	      " cm_add_dist) h:(cm_h_attribute + cm_add_dist) rx:0.1cm     ry:0.1cm
  CLIP_OFF
  PEN color:snow

  FILL color:snow
  ROUNDRECT x:(cm_x_start) y:(0.0cm + cm_h_space + 0.03cm) w:(cm_w_lastChange - 0.05cm) h:(cm_h_attri"
	      "bute - 0.05cm) rx:0.1cm ry:0.1cm
  ATTR \"Date last changed\" x:(cm_x_start + (cm_w_space / 2)) y:(cm_h_all / 2) h:c
  SET cm_x_start:(cm_x_start + cm_w_lastChange + (cm_w_space/2))
  #Hide model info
  # [HOs 2008-04-24: replaced TEXT by lines because the special characters \"‹\" and \"›\" are not su"
	      "pported by the codepage
  # which BOC recommends for usage on Oracle: Oracle-Codepage \"WE8ISO8859P15\" (CR#2323)
  # Font \"Arial Rounded MT Bold\" is not available on a standard Windows XP after default installati"
	      "on (CR#2322)
  #FONT \"Arial Rounded MT Bold\" h:15pt color:$838080
  #TEXT \"‹\" x:0.13cm y:0.3cm w:c h:c
  #PEN color:$838080 w:0.05cm endcap:round
  #LINE x1:0.13cm y1:0.25cm x2:0.08cm y2:0.35cm
  #LINE x1:0.08cm y1:0.35cm x2:0.13cm y2:0.45cm
   #HOTSPOT \"_ToggleModelInfo_\" text:\"Hide model information\" x:0.02cm y:0.0cm w:0.18cm h:0.7cm
ELSE   
  IF (_outdevtype = \"drawingarea\") 
    FILL style:null
    CLIP_ROUNDRECT x:0.0cm y:0.0cm w:.2cm h:0.7cm rx:0.07cm ry:0.07cm
      GRADIENT_RECT x:0.0cm y:0.0cm w:.2cm h:0.7cm style:vert
                    color1:$efefef color2:$bdbdbd
      PEN color:$b1b1b1 w:0.05cm join:bevel style:inside-frame
      ROUNDRECT x:0.0cm y:0.0cm w:.2cm h:0.7cm rx:0.07cm ry:0.07cm
    CLIP_OFF
    # [HOs 2008-04-24: replaced TEXT by lines because the special characters \"‹\" and \"›\" are not "
	      "supported by the codepage
    # which BOC recommends for usage on Oracle: Oracle-Codepage \"WE8ISO8859P15\" (CR#2323)
    # Font \"Arial Rounded MT Bold\" is not available on a standard Windows XP after default installa"
	      "tion (CR#2322)
    #FONT \"Arial Rounded MT Bold\" h:15pt color:$838080
    #TEXT \"›\" x:0.1cm y:0.3cm w:c h:c
    #PEN color:$838080 w:0.05cm endcap:round
    #LINE x1:0.08cm y1:0.25cm x2:0.13cm y2:0.35cm
    #LINE x1:0.13cm y1:0.35cm x2:0.08cm y2:0.45cm

    #HOTSPOT \"_ToggleModelInfo_\" text:\"Show model information\" x:0.02cm y:0.0cm w:0.18cm h:0.7cm

  ENDIF
 ENDIF


##Copyright
GRAPHREP layer:3
AVAL copy:\"Copyright info\"
# SET copyright:(copy)
 AVAL posi:\"Copyright info position\"
 IF (posi=\"Bottom left\")
    IF(copy = \"Edit the model attributes to display your copyright info\")
        FONT italic
    ENDIF
    ATTR \"Copyright info\" x:0cm y:(h - 1cm) w:l h:b
        FONT color:darkblue
    TEXT (\"Powered by ADOxx\") x:0cm y:(h - 0.5cm) w:l h:b
        FONT underline color:darkblue
    TEXT (\"www.adoxx.org\") x:0cm y:(h) w:l h:b
        #HOTSPOT \"_GoToAceHp_\" text:\"Visit adoxx.org homepage\" x:0cm y:(h) w:4cm h:1cm
 ELSIF (posi = \"Bottom right\")
    IF(copy = \"Edit the model attributes to display your copyright info\")
        FONT italic
    ENDIF
    ATTR \"Copyright info\" x:(w) y:(h - 1cm) w:r h:b
        FONT color:darkblue
    TEXT (\"Powered by ADOxx\") x:(w) y:(h - 0.5cm) w:r h:b
        FONT underline color:darkblue
        TEXT (\"www.adoxx.org\") x:(w) y:(h) w:r h:b
        #HOTSPOT \"_GoToAceHp_\" text:\"Visit adoxx.org homepage\" x:(w - 4cm) y:(h) w:4cm h:1cm
 ELSE
    IF(copy = \"Edit the model attributes to display your copyright info\")
        FONT italic
    ENDIF
        ATTR \"Copyright info\" x:(w) y:1cm w:r h:t
        FONT color:darkblue
    TEXT (\"Powered by ADOxx\") x:(w) y:1.5cm w:r h:t
        FONT underline color:darkblue
    TEXT (\"www.adoxx.org\") x:(w) y:2.0cm w:r h:t
#HOTSPOT \"_GoToAceHp_\" text:\"Visit adoxx.org homepage\" x:(w - 4cm) y:(h) y:1.5cm h:1cm
 ENDIF
##//Copyright


FONT h:12pt italic
TEXT \"Based on \\\"The Lean Canvas\\\" by Ash Maurya\" x:0.2cm y:(h-12pt) h:b
#FONT h:12pt color:darkblue style:\"underline\"
#TEXT \"www.ashmaurya.com/2012/02/why-lean-canvas/\" x:0.2cm y:(h) h:b
BITMAPINFO (\"db:\\\\cc.png\")
BITMAP (\"db:\\\\cc.png\") x:0.2cm y:(h-2.7cm-37pt) w:(bmpwidth / 96 * 2.54cm) h:(bmpheight / 96 * 2."
	      "54cm)
FONT h:12pt
TEXT \"This work is licensed under the Creative Commons Attribution-Share Alike 3.0 Unported License."
