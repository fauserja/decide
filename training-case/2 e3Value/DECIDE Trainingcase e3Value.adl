	VALUE "EXPR expr:(set(targets, ctobjs(\"Is inside\")),
cond
  (tokcnt(targets,\" \")=0,\"black\",
    (cond
      (tokcnt(targets,\" \")=1,aval (VAL ctobjs(\"Is inside\"), \"Fontcolor\"),
    (
    set(tk,token(targets,0,\" \")),
                set(t,VAL (copy(aval(VAL tk, \"Position\"),search(aval(VAL tk, \"Position\"),\"index\""
	      ",0)+6,-1))),
    fortok(x,targets,\" \",
        (
        set(c,VAL (copy(aval(VAL x, \"Position\"),search(aval(VAL x, \"Position\"),\"index\",0)+6,-1)"
	      ")),
        cond(c>=t,(set(res,x),set(t,c)),\"\")
        )),
                aval (VAL res, \"Fontcolor\")
    ))
   )
  )) val:\"black\""

