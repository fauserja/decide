FONT h:12pt color:darkblue style:\"underline\"
TEXT \"http://creativecommons.org/licenses/by-sa/3.0/ or send a letter to Creative Commons, 171 Secon"
	      "d Street, Suite 300, San Francisco, California, 94105, USA.\" x:0.2cm y:(h-1.7cm) h:b
