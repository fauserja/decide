{UTF-8}
Profit=
	Revenue-Costs
	~	€/Day
	~		|

Base Business Dev=
	2
	~	FTE
	~		|

Base Staff=
	5
	~	FTE
	~		|

Business Dev Effort  = A FUNCTION OF( Base Business Dev,Inventory Threshold) ~~|
Business Dev Effort=
	2
	~	FTE
	~		|

Whey Intake=
	MIN(Whey Supply, WPC80 Demand)
	~	t/Day
	~		|

Staff per t=
	100
	~	t/FTE
	~		|

Fixed Costs=
	2000
	~	€/Day
	~		|

Costs=
	Fixed Costs+(Whey Cost per t*Whey Intake)
	~	€/Day
	~		|

Whey Cost per t=
	1200
	~	€/t
	~		|

Inventory Threshold=
	200
	~	t
	~		|

Revenue=
	WPC80 Sales*WPC80 Price
	~	€/Day
	~		|

WPC80 Sales=
	MIN(WPC80 Demand, WPC80 Inventory)
	~	t/Day
	~		|

Acquisition WPC80=
	Business Dev Effort*Conversion Rate WPC80
	~	Customer/Day
	~		|

Order per customer=
	100
	~	t/Day
	~		|

Customer Base WPC80= INTEG (
	Acquisition WPC80-Churn Rate WPC80,
		3)
	~	Customer
	~		|

WPC80 Inventory= INTEG (
	WPC80 Produced-WPC80 Sales,
		0)
	~	t
	~		|

Churn Rate WPC80=
	Customer Base WPC80*Churn WPC80
	~	Customer/Day
	~		|

Churn WPC80=
	0.0005
	~	1/Day
	~		|

Conversion Rate WPC80=
	0.3
	~	Dmnl
	~		|

Yield WPC80=
	0.3
	~	Dmnl
	~		|

Whey Supply=
	625
	~	t/Day
	~		|

WPC80 Demand=
	Customer Base WPC80*Order per customer
	~	t/Day
	~		|

WPC80 Price=
	4000
	~	€/t
	~		|

WPC80 Produced=
	Whey Intake*Yield WPC80
	~	t/Day
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 365
	~	Day
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Day
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Day [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Day [0,?]
	~	The time step for the simulation.
	|

